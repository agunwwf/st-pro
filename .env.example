# Compose
SPRING_PROFILES_ACTIVE=prod
JAVA_OPTS=-Xms512m -Xmx1024m

# 无域名、仅 IP + HTTP 时：DOMAIN 可写 IP；FRONTEND_ORIGINS 必须包含 http://你的IP
DOMAIN=114.55.98.173

# MySQL（容器内仅 root 时：不要配置 MYSQL_USER，只配 root 密码 + 库名）
MYSQL_ROOT_PASSWORD=请修改
DB_HOST=mysql
DB_PORT=3306
DB_NAME=apple_admin
DB_USER=root
DB_PASSWORD=请与 MYSQL_ROOT_PASSWORD 一致

# Redis
REDIS_PASSWORD=
REDIS_DB=0

# JWT（需与线上约定一致；勿用弱口令）
JWT_SECRET=请修改为长随机串

FRONTEND_ORIGINS=http://你的公网IP,http://localhost:5173

# AI（可选，需要时再填）
DEEPSEEK_API_KEY=
DASHSCOPE_API_KEY=

API_BASE_URL=http://backend:8080
